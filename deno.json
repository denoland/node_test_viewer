{
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check **/*.ts && deno check **/*.tsx",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "nodeModulesDir": "auto",
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@kt3k/weak-value-map": "jsr:@kt3k/weak-value-map@^0.1.2",
    "@std/assert": "jsr:@std/assert@^1.0.18",
    "@std/async": "jsr:@std/async@^1.1.1",
    "@std/collections": "jsr:@std/collections@^1.1.5",
    "@std/streams": "jsr:@std/streams@^1.0.17",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "preact": "npm:preact@^10.28.3",
    "@preact/signals": "npm:@preact/signals@^2.7.0",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "components/": "./components/",
    "islands/": "./islands/",
    "util/": "./util/"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  },
  "unstable": [
    "kv"
  ]
}
